# Suvera storefront local environment example
# Copy to .env locally if your shell/dev tooling loads env files.
# Do not commit real tokens or production secrets.

UPSTREAM_API=https://panelya-api.example.com/api
SUVERA_PUBLIC_ACCESS_TOKEN=replace_with_public_storefront_access_token
SUVERA_SITE_ORIGIN=http://localhost:4173
# Cok magaza: her storefront deploy'u kendi slug/domain'ini set eder.
# Ornek magaza-2:  SUVERA_ORGANIZATION_SLUG=magaza-2  /  STORE_DOMAIN=magaza2.com.tr
SUVERA_ORGANIZATION_SLUG=suvera
STORE_DOMAIN=suvera.com.tr
HOST=127.0.0.1
PORT=4173
MAX_PROXY_BODY_BYTES=1048576
